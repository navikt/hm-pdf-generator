<!DOCTYPE html>
<html lang="nb">
<head>
    <meta charSet="UTF-8"/>
    <title>Bestilling av deler til reparasjon av hjelpemidler</title>
    {{> style}}

    <style>
        body {
            font-family: Arial, Helvetica, sans-serif;
            color: #2f2f2f;
            font-size: 14px;
            line-height: 1.3;
            margin: 0;
        }

        .page {
            padding: 20px 18px 28px 18px;
        }

        .header-banner {
            min-height: 48px;
            display: table;
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 14px;
        }

        .header-banner-inner {
            display: table-row;
        }

        .header-logo-cell,
        .header-title-cell {
            display: table-cell;
            vertical-align: middle;
        }

        .header-logo-cell {
            width: 64px;
            padding-left: 14px;
            padding-right: 10px;
        }

        .header-logo-cell svg,
        .header-logo-cell img {
            display: block;
            width: 64px;
            height: 20px;
        }

        .header-title-cell {
            font-weight: 700;
            font-size: 16px;
            color: #1f1f1f;
            padding: 12px 16px 12px 0;
        }

        .received-date {
            text-align: right;
            font-size: 14px;
            color: #3a3a3a;
            margin-bottom: 28px;
        }

        .section {
            margin-bottom: 32px;
        }

        .section-title {
            font-size: 19px;
            line-height: 1.2;
            font-weight: 700;
            color: #3a3a3a;
            margin: 0 0 10px 0;
        }

        .section-title.with-rule {
            border-bottom: 1px solid #bcc2c9;
            padding-bottom: 6px;
            margin-bottom: 10px;
        }

        .field-table {
            border-collapse: collapse;
            width: 100%;
            table-layout: fixed;
        }

        .field-table td {
            padding: 2px 0;
            vertical-align: top;
        }

        .field-label {
            width: 160px;
            font-weight: 700;
            color: #303030;
            white-space: nowrap;
            padding-right: 16px;
        }

        .field-value {
            color: #303030;
        }

        .info-note {
            margin-top: 8px;
            margin-bottom: 14px;
            font-size: 13px;
            color: #444;
        }

        .info-icon {
            display: inline-block;
            width: 13px;
            height: 13px;
            line-height: 13px;
            text-align: center;
            border: 1px solid #6f6f6f;
            color: #444;
            font-size: 10px;
            font-weight: 700;
            margin-right: 6px;
            vertical-align: 1px;
        }

        .parts-table {
            width: 100%;
            border-collapse: collapse;
            table-layout: fixed;
            margin-top: 4px;
        }

        .parts-table td {
            padding: 7px 0;
            vertical-align: top;
        }

        .parts-number {
            width: 110px;
            font-weight: 700;
            color: #303030;
            padding-right: 16px;
            white-space: nowrap;
        }

        .parts-name {
            color: #303030;
            padding-right: 16px;
        }

        .parts-name.manual {
            font-style: italic;
            color: #5a5a5a;
        }

        .parts-count {
            width: 70px;
            text-align: right;
            white-space: nowrap;
            color: #303030;
        }

        .parts-total {
            margin-top: 20px;
            border-top: 1px solid #7f8790;
            padding-top: 8px;
            text-align: right;
            font-weight: 700;
            color: #303030;
        }

        .section:last-child {
            margin-bottom: 0;
        }
    </style>
</head>
<body>
<div class="page">
    <div class="header-banner">
        <div class="header-banner-inner">
            <div class="header-logo-cell">
                {{> nav-logo }}
            </div>
            <div class="header-title-cell">
                Bestilling av deler til reparasjon av hjelpemidler
            </div>
        </div>
    </div>

    <div class="received-date">
        Mottatt dato: {{mottattDato}}
    </div>

    <section class="section">
        <h1 class="section-title">Hjelpemiddelbruker</h1>

        <table class="field-table">
            <tr>
                <td class="field-label">Navn</td>
                <td class="field-value">{{navnBruker}}</td>
            </tr>
            <tr>
                <td class="field-label">Fødselsnummer</td>
                <td class="field-value">{{fnrBruker}}</td>
            </tr>
            <tr>
                <td class="field-label">Folkeregistrert adresse</td>
                <td class="field-value">{{adresseBruker}}</td>
            </tr>
        </table>

        <div class="info-note">
            <span class="info-icon">i</span>
            Opplysningene over er hentet fra Folkeregisteret
        </div>

        {{#if brukernummer}}
            <table class="field-table">
                <tr>
                    <td class="field-label">Brukernummer</td>
                    <td class="field-value">{{brukernummer}}</td>
                </tr>
            </table>
        {{/if}}
    </section>

    <section class="section">
        <h1 class="section-title with-rule">Hjelpemidlet som skal repareres</h1>

        <table class="field-table">
            <tr>
                <td class="field-label">Hjelpemiddel</td>
                <td class="field-value">{{hjelpemiddelnavn}}</td>
            </tr>
            <tr>
                <td class="field-label">Art.nr.</td>
                <td class="field-value">{{hjelpemiddelHmsnr}}</td>
            </tr>
            {{#if hjelpemiddelserienr}}
                <tr>
                    <td class="field-label">Serienr.</td>
                    <td class="field-value">{{hjelpemiddelserienr}}</td>
                </tr>
            {{/if}}
        </table>
    </section>

    <section class="section">
        <h1 class="section-title with-rule">Deler til reparasjonen</h1>

        <table class="parts-table">
            <tbody>
            {{#each deler}}
                <tr>
                    <td class="parts-number">{{hmsnr}}</td>
                    <td class="parts-name">{{navn}}</td>
                    <td class="parts-count">{{antall}} stk.</td>
                </tr>
            {{/each}}

            {{#each ukjenteDeler}}
                <tr>
                    <td class="parts-number">
                        {{#if hmsnr}}{{hmsnr}}{{/if}}{{#if levArtnr}}{{levArtnr}}{{/if}}
                    </td>
                    <td class="parts-name manual">
                        {{#if hmsnr}}HMS artikkelnummer er fylt inn manuelt.{{/if}}
                        {{#if levArtnr}}Leverandørens artikkelnummer er fylt inn manuelt.{{/if}}
                    </td>
                    <td class="parts-count">{{antall}} stk.</td>
                </tr>
            {{/each}}
            </tbody>
        </table>

        <div class="parts-total">
            Totalt: {{totalAntallDeler}} stk.
        </div>
    </section>

    <section class="section">
        <h1 class="section-title with-rule">Utlevering</h1>

        <table class="field-table">
            <tr>
                <td class="field-label">Leveringsadresse</td>
                <td class="field-value">{{leveringsadresse}}</td>
            </tr>
            {{#if beskjed517}}
                <tr>
                    <td class="field-label">Beskjed til 5.17-skjema</td>
                    <td class="field-value">{{beskjed517}}</td>
                </tr>
            {{/if}}
            <tr>
                <td class="field-label">Bestilt av</td>
                <td class="field-value">{{navnTekniker}} (tekniker)</td>
            </tr>
        </table>
    </section>
</div>
</body>
</html>